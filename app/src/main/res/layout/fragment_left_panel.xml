<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/szu_bg"
    android:paddingStart="8dp"
    android:paddingEnd="4dp"
    android:paddingTop="8dp">

    <!-- 校园公网通 Module -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/border_box"
        android:padding="@dimen/padding_page">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_gongwangtong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="校园公网通"
                android:textColor="@color/szu_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_auth_notice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="《授权须知》"
                android:textColor="@color/szu_text_hint"
                android:textSize="@dimen/text_small" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="@color/szu_border"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spinner_user_type"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.55"
                android:background="@drawable/border_box"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <TextView
                android:id="@+id/btn_enter"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.45"
                android:layout_marginStart="8dp"
                android:text="进入公网通"
                android:textColor="@color/szu_text_primary"
                android:textSize="@dimen/text_body"
                android:gravity="center"
                android:background="@drawable/btn_white_border" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <!-- News Tab Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@color/szu_border">

        <TextView
            android:id="@+id/tab_important"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="1px"
            android:text="重要通知"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@color/szu_primary" />

        <TextView
            android:id="@+id/tab_news"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="1px"
            android:text="深大新闻"
            android:textColor="@color/szu_primary"
            android:textSize="@dimen/text_body"
            android:gravity="center"
            android:background="@color/white" />

        <TextView
            android:id="@+id/tab_lecture"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="学术讲座"
            android:textColor="@color/szu_primary"
            android:textSize="@dimen/text_body"
            android:gravity="center"
            android:background="@color/white" />
    </LinearLayout>

    <!-- News List with background image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/img_10003"
            android:scaleType="fitXY"
            android:alpha="0.999    "
            android:contentDescription="背景底图" />

        <LinearLayout
            android:id="@+id/news_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[专栏] 关于2026年五一放假安排的通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[科研] 国家自然科学基金项目申报通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[教务] 2025-2026学年第二学期选课通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[行政] 关于做好寒假期间安全工作的通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[科研] 深圳大学2026年国家社科基金申报公告" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[教务] 关于2026届毕业生毕业论文工作的通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[专栏] 学习贯彻党的二十届三中全会精神" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[科研] 关于征集2026年度重点研发计划项目指南" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[行政] 关于2026年教职工年度考核工作的通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[教务] 2026年硕士研究生招生考试考点公告" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[科研] 关于组织申报广东省重点实验室的通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[教务] 2026年本科生转专业工作通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[专栏] 深圳大学建校43周年校庆系列活动" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[行政] 关于2026年财务报销系统升级的通知" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="24dp" android:text="[科研] 2026年度深圳市科创委项目申报指南" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_small" android:gravity="center_vertical" android:singleLine="true" android:ellipsize="end" />
        </LinearLayout>

    </FrameLayout>

    <!-- Date Bar -->
    <TextView
        android:id="@+id/tv_date_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/date_bar_height"
        android:textColor="@color/white"
        android:textSize="@dimen/text_body"
        android:gravity="center"
        android:background="@color/szu_primary" />
</LinearLayout>
