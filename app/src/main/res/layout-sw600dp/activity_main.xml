<?xml version="1.0" encoding="utf-8"?>
<!-- Tablet: side-by-side 38/62 layout -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="vertical"
    android:background="@color/szu_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Fragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragment_header"
            android:name="com.example.ex3.ui.fragments.HeaderFragment"
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height" />

        <!-- Login Navigation Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_bar_height"
            android:orientation="horizontal"
            android:background="@color/szu_panel"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <View android:layout_width="22dp" android:layout_height="22dp" android:background="@drawable/ic_user_placeholder" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/tv_username" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="陈己润" android:textColor="@color/szu_text_primary" android:textSize="@dimen/text_body" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  |  " android:textColor="@color/szu_border" android:textSize="@dimen/text_body" />
            <TextView android:id="@+id/tv_personal_center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="个人中心" android:textColor="@color/szu_text_secondary" android:textSize="@dimen/text_body" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  |  " android:textColor="@color/szu_border" android:textSize="@dimen/text_body" />
            <TextView android:id="@+id/tv_register" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="注册" android:textColor="@color/szu_text_secondary" android:textSize="@dimen/text_body" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  |  " android:textColor="@color/szu_border" android:textSize="@dimen/text_body" />
            <TextView android:id="@+id/tv_help" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="说明" android:textColor="@color/szu_text_secondary" android:textSize="@dimen/text_body" />
        </LinearLayout>

        <!-- Main Content: Left 38% + Right 62% -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Left Panel -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragment_left_panel"
                android:name="com.example.ex3.ui.fragments.LeftPanelFragment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.38" />

            <!-- Right Panel -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragment_right_panel"
                android:name="com.example.ex3.ui.fragments.RightPanelFragment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.62" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
